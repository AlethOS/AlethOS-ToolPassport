{
  "profile_id": "generic",
  "profile_version": "0.3.0",
  "standard_id": "alethos-toolpassport",
  "standard_version": "0.3.0",
  "title": "Generic Tool Profile",
  "description": "Fallback checks for tools that cannot be classified reliably.",
  "selection": {
    "tool_type_candidates": [
      "generic"
    ],
    "minimum_confidence": 0,
    "fallback": true
  },
  "scope_limitations": [
    "Specialized interface and permission checks are not available until the tool type is classified."
  ],
  "checks": [
    {
      "check_id": "generic.capability_scope",
      "dimension": "capability_clarity",
      "question": "Are the tool's intended capabilities and explicit limitations documented?",
      "weight": 1,
      "required_evidence_types": [
        "official_docs",
        "github_readme"
      ],
      "high_risk": false,
      "scoring_rule_id": "positive_capability_v1"
    },
    {
      "check_id": "generic.interface_contract",
      "dimension": "interface_openness",
      "question": "Is at least one stable integration interface documented?",
      "weight": 1,
      "required_evidence_types": [
        "official_docs",
        "public_example"
      ],
      "high_risk": false,
      "scoring_rule_id": "positive_capability_v1"
    },
    {
      "check_id": "generic.automation_contract",
      "dimension": "automation_readiness",
      "question": "Are automated inputs, outputs, and failure behavior documented?",
      "weight": 1,
      "required_evidence_types": [
        "official_docs",
        "public_example"
      ],
      "high_risk": false,
      "scoring_rule_id": "positive_capability_v1"
    },
    {
      "check_id": "generic.export_path",
      "dimension": "data_portability",
      "question": "Is there a documented path to export user data or configuration?",
      "weight": 1,
      "required_evidence_types": [
        "official_docs"
      ],
      "high_risk": false,
      "scoring_rule_id": "positive_capability_v1"
    },
    {
      "check_id": "generic.permission_boundary",
      "dimension": "permission_risk",
      "question": "Are sensitive permissions and side effects explicitly documented and bounded?",
      "weight": 1.5,
      "required_evidence_types": [
        "official_docs",
        "github_readme"
      ],
      "high_risk": true,
      "scoring_rule_id": "bounded_risk_v1"
    },
    {
      "check_id": "generic.claim_traceability",
      "dimension": "evidence_quality",
      "question": "Can important capability and risk claims be traced to reviewable sources?",
      "weight": 1,
      "required_evidence_types": [
        "official_docs",
        "github_readme"
      ],
      "high_risk": false,
      "scoring_rule_id": "positive_capability_v1"
    },
    {
      "check_id": "generic.maintenance_signal",
      "dimension": "ecosystem_fit",
      "question": "Is there reviewable evidence of maintenance and integration guidance?",
      "weight": 1,
      "required_evidence_types": [
        "official_docs",
        "github_metadata"
      ],
      "high_risk": false,
      "scoring_rule_id": "positive_capability_v1"
    }
  ]
