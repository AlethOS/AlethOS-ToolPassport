# Application
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8080
DATABASE_URL=sqlite://data/toolpassport.db
ARTIFACT_ROOT=./runs

# Orchestrator
ORCHESTRATOR_COMMAND=python
ORCHESTRATOR_BACKEND_URL=http://127.0.0.1:8080

# GLM-5.1
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-5.1

# Testnet attestation only
# Choose one testnet first. Recommended initial target: Ethereum Sepolia.
# Sepolia CHAIN_ID is 11155111.
CHAIN_ID=
# HTTPS endpoint from the chosen testnet RPC provider. Treat embedded API keys
# as secrets.
RPC_URL=
# Dedicated testnet-only wallet private key. Never reuse a mainnet wallet.
PRIVATE_KEY=
# Set only after a human-approved deployment of ToolPassportRegistry.
REGISTRY_CONTRACT=

# Dashboard: public values only
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8080
