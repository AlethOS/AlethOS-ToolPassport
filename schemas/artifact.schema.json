{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alethos.local/schemas/artifact.schema.json",
  "title": "Stored Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_schema_version",
    "artifact_id",
    "run_id",
    "filename",
    "content_type",
    "size_bytes",
    "sha256_hash",
    "created_at"
  ],
  "properties": {
    "artifact_schema_version": {
      "const": "0.1.0"
    },
    "artifact_id": {
      "type": "string",
      "format": "uuid"
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "filename": {
      "type": "string",
      "minLength": 1
    },
    "content_type": {
      "type": "string",
      "minLength": 1
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "sha256_hash": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
