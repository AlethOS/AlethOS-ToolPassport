{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alethos.local/schemas/evidence-create.schema.json",
  "title": "Create Evidence Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_schema_version",
    "source_type",
    "source_url",
    "source_revision",
    "title",
    "excerpt",
    "retrieved_at",
    "snapshot_artifact_id",
    "supports",
    "contradicts",
    "metadata"
  ],
  "properties": {
    "evidence_schema_version": {
      "const": "0.2.0"
    },
    "source_type": {
      "enum": [
        "user_material",
        "official_website",
        "official_docs",
        "github_readme",
        "github_metadata",
        "public_example"
      ]
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://.+$"
    },
    "source_revision": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "excerpt": {
      "type": "string"
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "snapshot_artifact_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "supports": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contradicts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
