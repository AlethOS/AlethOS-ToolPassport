{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alethos.local/schemas/provenance.schema.json",
  "title": "Frozen Audit Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provenance_schema_version",
    "run_id",
    "freeze_version",
    "evidence_board_version",
    "passport_sequence",
    "passport_hash",
    "audit_log_hash",
    "evidence_manifest_hash",
    "onchain_run_id",
    "frozen_at"
  ],
  "properties": {
    "provenance_schema_version": {
      "const": "0.1.0"
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "freeze_version": {
      "type": "integer",
      "minimum": 1
    },
    "evidence_board_version": {
      "type": "integer",
      "minimum": 1
    },
    "passport_sequence": {
      "type": "integer",
      "minimum": 1
    },
    "passport_hash": {
      "$ref": "#/$defs/sha256"
    },
    "audit_log_hash": {
      "$ref": "#/$defs/sha256"
    },
    "evidence_manifest_hash": {
      "$ref": "#/$defs/sha256"
    },
    "onchain_run_id": {
      "$ref": "#/$defs/sha256"
    },
    "frozen_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$",
      "readOnly": true
    }
  }
}
