{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alethos.local/schemas/tool-identity-resolution.schema.json",
  "title": "Tool Identity Resolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resolution_version",
    "status",
    "normalized_identifiers",
    "tool_id",
    "candidate_tool_ids",
    "reason_codes"
  ],
  "properties": {
    "resolution_version": {
      "const": "0.1.0"
    },
    "status": {
      "enum": [
        "resolved",
        "create_candidate",
        "needs_review"
      ]
    },
    "normalized_identifiers": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/external_identifier"
      }
    },
    "tool_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(github|url):[^\\s]+$"
    },
    "candidate_tool_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/tool_id"
      }
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "existing_identifier_match",
          "new_strong_identifier",
          "name_only",
          "name_match_only",
          "invalid_or_ambiguous_url",
          "multiple_strong_identifiers",
          "conflicting_existing_identifiers",
          "possible_fork_or_source_migration",
          "additional_identifier_requires_review"
        ]
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "tool_id": {
      "type": "string",
      "pattern": "^(github|url):[^\\s]+$"
    },
    "https_url": {
      "type": "string",
      "pattern": "^https://[^\\s]+$"
    },
    "external_identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace",
        "value",
        "canonical_url"
      ],
      "properties": {
        "namespace": {
          "enum": [
            "github",
            "url"
          ]
        },
        "value": {
          "$ref": "#/$defs/non_empty_string"
        },
        "canonical_url": {
          "$ref": "#/$defs/https_url"
        }
      }
    }
  }
}
