{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alethos.local/schemas/evidence-board.schema.json",
  "title": "Frozen Evidence Board",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_board_schema_version",
    "run_id",
    "version",
    "standard_id",
    "standard_version",
    "profile_id",
    "profile_version",
    "evidence_ids",
    "claims",
    "gaps",
    "freeze_reason",
    "frozen_at"
  ],
  "properties": {
    "evidence_board_schema_version": {
      "const": "0.1.0"
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "standard_id": {
      "$ref": "#/$defs/stable_id"
    },
    "standard_version": {
      "$ref": "#/$defs/semantic_version"
    },
    "profile_id": {
      "$ref": "#/$defs/stable_id"
    },
    "profile_version": {
      "$ref": "#/$defs/semantic_version"
    },
    "evidence_ids": {
      "$ref": "#/$defs/evidence_ids"
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gap"
      }
    },
    "freeze_reason": {
      "$ref": "#/$defs/non_empty_string"
    },
    "frozen_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "semantic_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "check_id",
        "statement",
        "status",
        "confidence",
        "supports",
        "contradicts"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/stable_id"
        },
        "check_id": {
          "$ref": "#/$defs/stable_id"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "enum": [
            "supported",
            "partially_supported",
            "unsupported",
            "contradicted",
            "not_checked"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "supports": {
          "$ref": "#/$defs/evidence_ids"
        },
        "contradicts": {
          "$ref": "#/$defs/evidence_ids"
        }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "check_id",
        "description",
        "priority",
        "status",
        "resolution"
      ],
      "properties": {
        "gap_id": {
          "$ref": "#/$defs/stable_id"
        },
        "check_id": {
          "$ref": "#/$defs/stable_id"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "priority": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "status": {
          "enum": [
            "open",
            "resolved",
            "accepted"
          ]
        },
        "resolution": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
