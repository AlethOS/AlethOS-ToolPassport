{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alethos.local/schemas/check-results-submission.schema.json",
  "title": "Check Results Submission",
  "description": "Untrusted finding proposals submitted for deterministic Rust scoring.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "check_results_schema_version",
    "evidence_board_version",
    "findings"
  ],
  "properties": {
    "check_results_schema_version": {
      "const": "0.1.0"
    },
    "evidence_board_version": {
      "type": "integer",
      "minimum": 1
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/finding"
      }
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "finding",
        "rationale",
        "evidence_ids",
        "not_applicable_reason"
      ],
      "properties": {
        "check_id": {
          "$ref": "#/$defs/stable_id"
        },
        "finding": {
          "enum": [
            "pass",
            "partial",
            "fail",
            "unknown",
            "not_applicable"
          ]
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ids": {
          "$ref": "#/$defs/evidence_ids"
        },
        "not_applicable_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
